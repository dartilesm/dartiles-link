---
import LinkList from "@/components/link/link-list.astro";
import BytebuzzLogo from "../../public/bytebuzz-logo.svg?raw";
import { ExternalLinkIcon } from "@/components/icons";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
---

<div class='min-h-screen flex-1 flex flex-col justify-center items-center px-0 py-16 gap-6'>
  <div class='relative'>
    <span
      class='animate-ping absolute inline-flex h-3 w-3 rounded-full bg-secondary opacity-75 z-10 -top-0.5 right-0.5'
    ></span>
    <span class='absolute inline-flex rounded-full h-3 w-3 bg-secondary z-20 -top-0.5 right-0.5'
    ></span>
    <a
      href='https://bytebuzz.dev/'
      target='_blank'
      rel='noopener noreferrer'
      class={cn(
        buttonVariants({ size: "lg" }),
        "relative bg-gradient-to-tr from-blue-900 to-purple-900 text-white shadow-lg font-medium flex flex-row justify-between items-center gap-2 rounded-full h-10 px-6 hover:opacity-90 [&_svg]:size-5 [&_svg]:shrink-0 [&>svg]:w-5 [&>svg]:h-5 [&>svg>*]:fill-current",
      )}
    >
      <Fragment set:html={BytebuzzLogo} />
      Building ByteBuzz
      <ExternalLinkIcon size={14} className='size-3.5 shrink-0' />
    </a>
  </div>
  <div class='relative mx-0 flex justify-center items-center h-72 aspect-square'>
    <img
      src='/me.webp'
      alt='Diego Artiles'
      width='208'
      height='208'
      class='w-52 h-52 rounded-full object-cover ring-2 ring-border ring-offset-2 ring-offset-[#0d1a36]'
    />
    <img
      src='/logo.webp'
      alt='dartiles logo'
      width='40'
      height='40'
      class='absolute m-0 z-50 bottom-4 rounded-full w-10 h-10 bg-white border-2 border-solid object-cover p-1'
    />
  </div>
  <div class='flex gap-2 flex-col'>
    <h1 class='text-4xl text-center'>Diego Artiles</h1>
    <h2 class='text-base sm:text-lg text-center text-balance max-w-sm px-4'>
      Senior frontend dev · building Bytebuzz · sharing what I learn
    </h2>
  </div>
  <LinkList />
</div>
